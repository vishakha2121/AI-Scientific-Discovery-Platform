echo ".env" >> .gitignore
echo ".env.local" >> .gitignore
echo ".env.dev" >> .gitignore
echo ".env.prod" >> .gitignore
echo ".env.test" >> .gitignore
echo "" >> .gitignore
echo "# Database" >> .gitignore
echo "*.db" >> .gitignore
echo "*.sqlite" >> .gitignore
echo "*.sqlite3" >> .gitignore
echo "" >> .gitignore
echo "# IDE" >> .gitignore
echo ".vscode/" >> .gitignore
echo ".idea/" >> .gitignore
echo "*.swp" >> .gitignore
echo "*.swo" >> .gitignore
echo "" >> .gitignore
echo "# Logs" >> .gitignore
echo "logs/" >> .gitignore
echo "*.log" >> .gitignore
echo "" >> .gitignore
echo "# OS" >> .gitignore
echo ".DS_Store" >> .gitignore
echo "Thumbs.db" >> .gitignore
echo "" >> .gitignore
echo "# Docker" >> .gitignore
echo "*.pid" >> .gitignore
echo "*.pid.lock" >> .gitignore
echo "" >> .gitignore
echo "# ML Models" >> .gitignore
echo "*.pth" >> .gitignore
echo "*.pt" >> .gitignore
echo "*.onnx" >> .gitignore
echo "*.h5" >> .gitignore
echo "*.pb" >> .gitignore
echo "*.tflite" >> .gitignore
echo "" >> .gitignore
echo "# Vector Store" >> .gitignore
echo "*.faiss" >> .gitignore
echo "index.*" >> .gitignore
echo "" >> .gitignore
echo "# Uploads" >> .gitignore
echo "uploads/" >> .gitignore
echo "media/" >> .gitignore
echo "static/" >> .gitignore
echo "" >> .gitignore
echo "# Temporary" >> .gitignore
echo "tmp/" >> .gitignore
echo "temp/" >> .gitignore
echo "*.tmp" >> .gitignore
echo "" >> .gitignore
echo "# Coverage" >> .gitignore
echo ".coverage" >> .gitignore
echo "htmlcov/" >> .gitignore
echo ".pytest_cache/" >> .gitignore
echo ".mypy_cache/" >> .gitignore
echo ".ruff_cache/" >> .gitignore
echo "" >> .gitignore
echo "# Jupyter" >> .gitignore
echo ".ipynb_checkpoints/" >> .gitignore
echo "*.ipynb" >> .gitignore
echo "" >> .gitignore
echo "# Backup" >> .gitignore
echo "*.bak" >> .gitignore
echo "backup/" >> .gitignore

# 3. Initialize Git
git init

# 4. Add all files
git add .

# 5. Commit files
git commit -m "Initial commit - AI Scientific Discovery Platform with Hypothesis Generation, Knowledge Graph, RAG, and GNN features"

