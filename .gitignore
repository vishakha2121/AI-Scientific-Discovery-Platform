echo "*.db" >> .gitignore
echo "*.sqlite" >> .gitignore
echo "*.sqlite3" >> .gitignore
echo "" >> .gitignore
echo "# IDE" >> .gitignore
echo ".vscode/" >> .gitignore
echo ".idea/" >> .gitignore
echo "*.swp" >> .gitignore
echo "*.swo" >> .gitignore
echo "" >> .gitignore
echo "# Logs" >> .gitignore
echo "logs/" >> .gitignore
echo "*.log" >> .gitignore
echo "" >> .gitignore
echo "# OS" >> .gitignore
echo ".DS_Store" >> .gitignore
echo "Thumbs.db" >> .gitignore
echo "" >> .gitignore
echo "# Docker" >> .gitignore
echo "*.pid" >> .gitignore
echo "*.pid.lock" >> .gitignore
echo "" >> .gitignore
echo "# ML Models" >> .gitignore
echo "*.pth" >> .gitignore
echo "*.pt" >> .gitignore
echo "*.onnx" >> .gitignore
echo "*.h5" >> .gitignore
echo "*.pb" >> .gitignore
echo "*.tflite" >> .gitignore
echo "" >> .gitignore
echo "# Vector Store" >> .gitignore
echo "*.faiss" >> .gitignore
echo "index.*" >> .gitignore
echo "" >> .gitignore
echo "# Uploads" >> .gitignore
echo "uploads/" >> .gitignore
echo "media/" >> .gitignore
echo "static/" >> .gitignore
echo "" >> .gitignore
echo "# Temporary" >> .gitignore
echo "tmp/" >> .gitignore
echo "temp/" >> .gitignore
