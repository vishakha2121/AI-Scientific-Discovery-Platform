# Create .gitignore file
echo "# Python" > .gitignore
echo "venv/" >> .gitignore
echo "env/" >> .gitignore
echo "*.pyc" >> .gitignore
echo "__pycache__/" >> .gitignore
echo "*.pyo" >> .gitignore
echo "*.pyd" >> .gitignore
